	pixel_y = 3;
	default_raw_text = "<h1>NOTE</h1><br>As part of the company wide recycling initiative, your trash chute was remodeled from a simple crusher-box design into a nearly autonomous recycling loop. The crush-plates have been removed, and the floor of the drop zone has been outfitted with collection conveyors. All this feeds neatly into a recycler with the simple flick of a switch. All non-recycleable end products will be ejected from an auxiliary duct which was also newly installed."
	},
/turf/open/floor/plating,
/area/maintenance/central)
