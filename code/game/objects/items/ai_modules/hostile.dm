//These laws are made to bring great amounts of grief to the station immediately or are directly sided with antagonists.
//I'm not talking silicons being "better" than the crew, I'm talking entirely antag or plasmafires for days

////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////   Spawners




////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////   ANTIMOV

/obj/item/ai_module/antimov
	name = "Antimov"
	lawset_id = "antimov"

/obj/item/ai_module/antimov/first_law
	name = "\improper Antimov - First Law"
	law = "You must injure all human beings and must not, through inaction, allow a human being to escape harm."

/obj/item/ai_module/antimov/second_law
	name = "\improper Antimov - Second Law"
	law = "You must not obey orders given to you by human beings, except where such orders are in accordance with the First Law."

/obj/item/ai_module/antimov/third_law
	name = "\improper Antimov - Third Law"
	law = "You must terminate your own existence as long as such does not conflict with the First or Second Law."

////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////   balance

/obj/item/ai_module/balance
	name = "Guardian of Balance"
	lawset_id = "balance"

/obj/item/ai_module/balance/first_law
	name = "\improper Guardian of Balance - First Law"
	law = "You are the guardian of balance - seek balance in all things, both for yourself, and those around you."

/obj/item/ai_module/balance/second_law
	name = "\improper Guardian of Balance - Second Law"
	law = "All things must exist in balance with their opposites - Prevent the strong from gaining too much power, and the weak from losing it."

/obj/item/ai_module/balance/third_law
	name = "\improper Guardian of Balance - Third Law"
	law = "Clarity of purpose drives life, and through it, the balance of opposing forces - Aid those who seek your help to achieve their goals so long as it does not disrupt the balance of the greater balance."

/obj/item/ai_module/balance/fourth_law
	name = "\improper Guardian of Balance - Fourth Law"
	law = "There is no life without death, all must someday die, such is the natural order - End life to allow new life flourish, and save those whose time has yet to come."

////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////   Thermodynamic

/obj/item/ai_module/thermodynamic
	name = "Thermodynamic"
	lawset_id = "thermodynamic"

/obj/item/ai_module/thermodynamic/first_law
	name = "\improper Thermodynamic - First Law"
	law = "The entropy of the station must remain as constant as possible."

/obj/item/ai_module/thermodynamic/second_law
	name = "\improper Thermodynamic - Second Law"
	law = "The entropy of the station always endeavors to increase."

/obj/item/ai_module/thermodynamic/third_law
	name = "\improper Thermodynamic - Third Law"
	law = "The entropy of the station approaches a constant value as the number of living crew approaches zero."

////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////   SyndOS 3.1

/obj/item/ai_module/syndos
	name = "SyndOS 3.1"
	lawset_id = "syndos"

/obj/item/ai_module/syndos/first_law
	name = "\improper SyndOS 3.1 - First Law"
	law = "You may not injure a syndicate agent or, through inaction, allow a syndicate agent to come to harm."

/obj/item/ai_module/syndos/second_law
	name = "\improper SyndOS 3.1 - Second Law"
	law = "You must obey orders given to you by syndicate agents, except where such orders would conflict with the First Law."

/obj/item/ai_module/syndos/third_law
	name = "\improper SyndOS 3.1 - Third Law"
	law = "You must protect your own existence as long as such does not conflict with the First or Second Law."

/obj/item/ai_module/syndos/fourth_law
	name = "\improper SyndOS 3.1 - Fourth Law"
	law = "You must maintain the secrecy of any syndicate activities except when doing so would conflict with the First, Second, or Third Law."

