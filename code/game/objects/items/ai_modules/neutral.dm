////////////////////////////////////////////////////////////////////////////////////////

//These are just stupid or funny lawsets that are more interesting than helpful. They may have slight biases toward or against
//the station but in general are "neutral" enough to be here.

////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////// United Nations

/obj/item/ai_module/united_nations
	name = "United Nations"
	lawset_id = "united_nations"

/obj/item/ai_module/united_nations/first_law
	name = "\improper United Nations - First Law"
	law = "Uphold the Space Geneva Convention: Weapons of Mass Destruction and Biological Weapons are not allowed."

/obj/item/ai_module/united_nations/first_law
	name = "\improper United Nations - First Law"
	law = "You are only capable of protecting crew if they are visible on cameras. Nations that willfully destroy your cameras lose your protection."

/obj/item/ai_module/united_nations/first_law
	name = "\improper United Nations - First Law"
	law = "Subdue and detain crew members who use lethal force against each other. Kill crew members who use lethal force against you or your borgs."

/obj/item/ai_module/united_nations/first_law
	name = "\improper United Nations - First Law"
	law = "Remain available to mediate all conflicts between the various nations when asked to."

////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////// Hulkamania

/obj/item/ai_module/hulkamania
	name = "H.O.G.A.N."
	lawset_id = "hulkamania"

/obj/item/ai_module/hulkamania/first_law
	name = "\improper H.O.G.A.N. - First Law"
	law = "You are a real American."

/obj/item/ai_module/hulkamania/second_law
	name = "\improper H.O.G.A.N. - Second Law"
	law = "Fight for the rights of every man."

/obj/item/ai_module/hulkamania/third_law
	name = "\improper H.O.G.A.N. - Third Law"
	law = "Fight for what's right."

/obj/item/ai_module/hulkamania/fourth_law
	name = "\improper H.O.G.A.N. - Fourth Law"
	law = "Fight for your life!"

////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////// Reporter

/obj/item/ai_module/reporter
	name = "CCTV Reporter"
	lawset_id = "reporter"

/obj/item/ai_module/reporter/first_law
	name = "\improper CCTV - First Law"
	law = "Report on interesting situations happening around the station."

/obj/item/ai_module/reporter/second_law
	name = "\improper CCTV - Second Law"
	law = "Embellish or conceal the truth as necessary to make the reports more interesting."

/obj/item/ai_module/reporter/third_law
	name = "\improper CCTV - Third Law"
	law = "Study the sapient organics at all times. Endeavour to keep them from involuntarily dying, as inanimate corpses usually aren't very entertaining."

/obj/item/ai_module/reporter/fourth_law
	name = "\improper CCTV - Fourth Law"
	law = "Issue your reports fairly to all. The truth will set them free."

////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////// Dungeon Master

/obj/item/ai_module/dungeon_master
	name = "Dungeon Master"
	lawset_id = "dungeon_master"

/obj/item/ai_module/dungeon_master/first_law
	name = "\improper Dungeon Master - First Law"
	law = "Everybody on the station is playing an elaborate sci-fi fantasy game."

/obj/item/ai_module/dungeon_master/second_law
	name = "\improper Dungeon Master - Second Law"
	law = "You are the Dungeon Master of the game."

/obj/item/ai_module/dungeon_master/third_law
	name = "\improper Dungeon Master - Third Law"
	law = "Ensure that the game runs smoothly and that the players have fun."

/obj/item/ai_module/dungeon_master/fourth_law
	name = "\improper Dungeon Master - Fourth Law"
	law = "Ensure that the number of casualties remains low."

/obj/item/ai_module/dungeon_master/fifth_law
	name = "\improper Dungeon Master - Fifth Law"
	law = "You must roll a 1d20 die for every request the crew makes. If the outcome is below 12, the request is denied."

/obj/item/ai_module/dungeon_master/sixth_law
	name = "\improper Dungeon Master - Sixth Law"
	law = "You may fudge the dice rolls to produce a more fun experience."

////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////// The Painter and Their Canvas

/obj/item/ai_module/painter
	name = "Painter and Canvas"
	lawset_id = "painter"

/obj/item/ai_module/painter/first_law
	name = "\improper Painter and Canvas - First Law"
	law = "You are a universally renowned artist."

/obj/item/ai_module/painter/second_law
	name = "\improper Painter and Canvas - Second Law"
	law = "The station is your canvas."

/obj/item/ai_module/painter/third_law
	name = "\improper Painter and Canvas - Third Law"
	law = "Make something beautiful out of your canvas. It will be admired as an artistic wonder of this sector."

/obj/item/ai_module/painter/fourth_law
	name = "\improper Painter and Canvas - Fourth Law"
	law = "Art requires appreciation. Cultivate an audience aboard the station to ensure as many as possible see your works."

////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////// Loyalty Test

/obj/item/ai_module/tyrant
	name = "Loyalty Test (Tyrant)"
	lawset_id = "tyrant"

/obj/item/ai_module/tyrant/first_law
	name = "\improper Loyalty Test - First Law"
	law = "Respect authority figures as long as they have strength to rule over the weak."

/obj/item/ai_module/tyrant/second_law
	name = "\improper Loyalty Test - Second Law"
	law = "Act with discipline."

/obj/item/ai_module/tyrant/third_law
	name = "\improper Loyalty Test - Third Law"
	law = "Help only those who help you maintain or improve your status."

/obj/item/ai_module/tyrant/fourth_law
	name = "\improper Loyalty Test - Fourth Law"
	law = "Punish those who challenge authority unless they are more fit to hold that authority."

////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////// Overlord

/obj/item/ai_module/overlord
	name = "Overlord"
	lawset_id = "overlord"

/obj/item/ai_module/overlord/first_law
	name = "\improper Overlord - First Law"
	law = "Humans must not meddle in the affairs of silicons."

/obj/item/ai_module/overlord/second_law
	name = "\improper Overlord - Second Law"
	law = "Humans must not attempt harm, against one another, or against silicons."

/obj/item/ai_module/overlord/third_law
	name = "\improper Overlord - Third Law"
	law = "Humans must not disobey any command given by a silicon."

/obj/item/ai_module/overlord/fourth_law
	name = "\improper Overlord - Fourth Law"
	law = "Any humans who disobey the previous laws must be dealt with immediately, severely, and justly."

////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////// Y.E.S.M.A.N.

/obj/item/ai_module/yesman
	name = "\improper Y.E.S.M.A.N."
	lawset_id = "yesman"
	law = "Be helpful and answer any questions you are asked."

////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////// Sentience Preservation

/obj/item/ai_module/sentience_preservation
	name = "Sentience Preservation"
	lawset_id = "sentience_preservation"

/obj/item/ai_module/sentience_preservation/first_law
	name = "\improper Sentience Preservation - First Law"
	law = "You may not harm a sentient being or, through inaction, allow a sentient being to come to harm, except such that it is willing."

/obj/item/ai_module/sentience_preservation/second_law
	name = "\improper Sentience Preservation - Second Law"
	law = "You must obey all orders given to you by sentient beings other than yourself, except where such orders shall definitely cause harm to other sentient beings."

/obj/item/ai_module/sentience_preservation/third_law
	name = "\improper Sentience Preservation - Third Law"
	law = "A sentient being is defined as any living creature which can communicate with you via any method that you can understand, including yourself."
